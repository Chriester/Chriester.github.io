---
const technicalSkills = ['HTML', 'CSS/SCSS', 'JavaScript', 'TypeScript', 'React', 'TailwindCSS', 'Python'];
const softSkills = ['Communication', 'Teamwork', 'Problem Solving', 'Adaptability'];
---

<section id="skills" class="section py-20 bg-dark text-accent px-4">
  <div class="container mx-auto max-w-4xl">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">My Skills</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-12">
      <div>
        <h3 class="text-xl font-semibold mb-4 text-blue-400">Technical Skills</h3>
        <ul class="space-y-4">
          {technicalSkills.map((skill) => (
            <li class="flex items-center gap-3">
              <span class="text-blue-400 font-bold">✓</span>
              <span>{skill}</span>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-xl font-semibold mb-4 text-blue-400">Soft Skills</h3>
        <ul class="space-y-4">
          {softSkills.map((skill) => (
            <li class="flex items-center gap-3">
              <span class="text-blue-400 font-bold">✓</span>
              <span>{skill}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
