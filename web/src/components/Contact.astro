<section id="contact" class="section py-20 bg-dark text-accent px-4">
  <div class="container mx-auto max-w-4xl">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">Contact Me</h2>

    <form class="max-w-md mx-auto space-y-4">
      <div>
        <label for="name" class="block text-sm font-medium mb-2">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          class="w-full rounded-lg bg-dark-light border border-line px-4 py-2 text-accent focus:outline-none focus:ring-2 focus:ring-blue-400"
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-medium mb-2">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          class="w-full rounded-lg bg-dark-light border border-line px-4 py-2 text-accent focus:outline-none focus:ring-2 focus:ring-blue-400"
        />
      </div>

      <div>
        <label for="message" class="block text-sm font-medium mb-2">Message</label>
        <textarea
          id="message"
          name="message"
          rows="4"
          class="w-full rounded-lg bg-dark-light border border-line px-4 py-2 text-accent focus:outline-none focus:ring-2 focus:ring-blue-400"
        ></textarea>
      </div>

      <button
        type="button"
        class="w-full bg-blue-500 hover:bg-blue-600 text-white font-semibold px-6 py-2 rounded-lg transition-colors"
      >
        Send Message
      </button>
    </form>
  </div>
</section>
